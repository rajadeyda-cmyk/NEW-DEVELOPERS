<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Coffee Masters</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background-color: #f2f2f2;
      color: #5c3b28;
    }

    /* HEADER */
    .header {
      background-color: #4b220f;
      color: white;
      padding: 18px;
      text-align: center;
      font-weight: bold;
      font-size: 20px;
    }

    /* MAIN LAYOUT */
    .container {
      width: 95%;
      margin: 30px auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }

    /* CARD */
    .card {
      background-color: #f3e5d8;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .card-title {
      color: #9b5d36;
      margin-bottom: 25px;
      font-size: 22px;
      font-weight: bold;
    }

    /* ITEMS */
    .item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 25px;
      padding-bottom: 20px;
      border-bottom: 1px solid #ddb892;
    }

    .item:last-child {
      border-bottom: none;
    }

    .item-left {
      display: flex;
      gap: 15px;
    }

    .qty {
      color: #7a5a45;
    }

    .item-name {
      font-weight: bold;
      font-size: 20px;
    }

    .item-detail {
      color: #9b5d36;
      margin-top: 5px;
    }

    .price {
      font-weight: bold;
      font-size: 20px;
    }

    /* INPUT GROUP */
    .input-group {
      position: relative;
      margin-bottom: 25px;
    }

    .input-group label {
      position: absolute;
      top: -10px;
      left: 18px;
      background-color: #f3e5d8;
      padding: 0 5px;
      color: #9b5d36;
      font-size: 14px;
    }

    .input-group input {
      width: 100%;
      padding: 15px;
      border: 2px solid #9b5d36;
      border-radius: 30px;
      background-color: transparent;
      font-size: 18px;
      outline: none;
    }

    .small-input {
      width: 40%;
    }

    /* TOTAL SECTION */
    .totals {
      width: 300px;
      margin: 80px auto 30px;
    }

    .total-line {
      display: flex;
      justify-content: space-between;
      margin-bottom: 15px;
      font-size: 20px;
    }

    .grand-total {
      font-weight: bold;
      font-size: 24px;
    }

    /* BUTTON */
    .order-btn {
      display: block;
      width: 90%;
      margin: 30px auto;
      padding: 18px;
      background-color: #ddb892;
      border: none;
      border-radius: 40px;
      font-size: 20px;
      color: #5c3b28;
      cursor: pointer;
      transition: 0.3s;
    }

    .order-btn:hover {
      background-color: #c99d73;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .container {
        grid-template-columns: 1fr;
      }

      .small-input {
        width: 100%;
      }

      .totals {
        width: 90%;
      }
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <div class="header">
    ☕ Coffee Masters
  </div>

  <!-- MAIN -->
  <div class="container">

    <!-- LEFT CARD -->
    <div class="card">

      <div class="card-title">ITEMS</div>

      <div class="item">
        <div class="item-left">
          <div class="qty">1x</div>

          <div>
            <div class="item-name">Cappuccino</div>
            <div class="item-detail">Lite foam</div>
          </div>
        </div>

        <div class="price">$3.35</div>
      </div>

      <div class="item">
        <div class="item-left">
          <div class="qty">1x</div>

          <div>
            <div class="item-name">Cappuccino</div>
            <div class="item-detail">Lite milk</div>
            <div class="item-detail">Double espresso</div>
          </div>
        </div>

        <div class="price">$3.85</div>
      </div>

      <div class="item">
        <div class="item-left">
          <div class="qty">1x</div>

          <div>
            <div class="item-name">Croissant</div>
            <div class="item-detail">Butter</div>
          </div>
        </div>

        <div class="price">$2.45</div>
      </div>

    </div>

    <!-- RIGHT SIDE -->
    <div>

      <!-- NAME -->
      <div class="card">

        <div class="card-title">NAME</div>

        <div class="input-group">
          <label>Name for order</label>
          <input type="text" value="Ford Prefect">
        </div>

      </div>

      <br>

      <!-- PAYMENT -->
      <div class="card">

        <div class="card-title">PAYMENT</div>

        <div class="input-group">
          <label>Card number</label>
          <input type="text" value="1234 5678 9012 3456">
        </div>

        <div class="input-group small-input">
          <label>CCV Number</label>
          <input type="text" value="001">
        </div>

      </div>

    </div>

  </div>

  <!-- TOTALS -->
  <div class="totals">

    <div class="total-line">
      <span>Subtotal:</span>
      <span>$9.65</span>
    </div>

    <div class="total-line">
      <span>Tax:</span>
      <span>$0.82</span>
    </div>

    <div class="total-line grand-total">
      <span>Total:</span>
      <span>$10.47</span>
    </div>

  </div>

  <!-- BUTTON -->
  <button class="order-btn">
    Place order
  </button>

</body>
</html>